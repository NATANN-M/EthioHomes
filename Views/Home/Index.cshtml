    @if (ViewBag.ShowReminder == true)
    {
        <div id="reminderModal" class="modal show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Your stay is almost over!</h5>
                    </div>
                    <div class="modal-body">
                        <p>Would you like to book again?</p>
                    </div>
                    <div class="modal-footer">
                        <form method="post" action="@Url.Action("HandleReminderDecision", "Home")">

                            <input type="hidden" name="bookingId" value="@ViewBag.BookingId" />
                            <button type="submit" name="decision" value="BookAgain" class="btn btn-primary">Book Again</button>
                            <button type="submit" name="decision" value="Later" class="btn btn-secondary">Later</button>
                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#confirmCancelModal">Cancel Booking</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cancel confirmation modal -->
        <div id="confirmCancelModal" class="modal fade" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" action="@Url.Action("HandleReminderDecision", "Home")">

                        <div class="modal-header">
                            <h5 class="modal-title">Are you sure?</h5>
                        </div>
                        <div class="modal-body">
                            <p>Do you really want to cancel this booking?</p>
                        </div>
                        <div class="modal-footer">
                            <input type="hidden" name="bookingId" value="@ViewBag.BookingId" />
                            <button type="submit" name="decision" value="Cancel" class="btn btn-danger">Yes, Cancel</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
    

    <!-- Modal Notification -->
    <div class="modal fade" id="notificationModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Notification</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (ViewBag.UserType == "Owner")
                    {
                        <p>You have pending booking requests!</p>
                    }
                    else 
                    {
                        <p>Your booking request has been approved!</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>


    <!-- Bootstrap JS -->
    <script src="~/js/bootstrap.bundle.min.js"></script>

    


    <script src="/js/jquery.min.js"></script>
    <script src="/js/owl.carousel.min.js"></script>

    <script>

           document.addEventListener('DOMContentLoaded', function() {
            // Convert C# boolean to JS boolean
            const hasPending = @(ViewBag.HasPendingRequests.ToString().ToLower());
            const hasApproval = @(ViewBag.HasApprovalNotification.ToString().ToLower());

            console.log("Pending:", hasPending);
            console.log("Approved:", hasApproval);

            if (hasPending || hasApproval) {
                new bootstrap.Modal(document.getElementById('notificationModal')).show();
            }
        });



        $(document).ready(function () {
        $(".owl-carousel").owlCarousel({
        items: 1,
        loop: true,
        autoplay: true,
        autoplayTimeout: 3000,
        dots: true,
        nav: true,
        navText: ["<", ">"],
        responsive: {
        0: {
        items: 1
        },
        600: {
        items: 1
        },
        1000: {
        items: 1
        }
        }
        });

        // Add keyboard navigation
        $(document).keydown(function (e) {
        if (e.keyCode == 37) { // Left arrow key
        $(".owl-carousel").trigger('prev.owl.carousel');
        } else if (e.keyCode == 39) { // Right arrow key
        $(".owl-carousel").trigger('next.owl.carousel');
        }
        });
        });
        

       
        // Show the modal if it exists
        document.addEventListener("DOMContentLoaded", function () {
            var successModal = document.getElementById('successModal');
            if (successModal) {
                var modal = new bootstrap.Modal(successModal);
                modal.show();
            }
        });
    
    </script>

</body>

</html> 