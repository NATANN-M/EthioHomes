                    @* <li class="nav-item"> *@
                    @*     <a class="nav-link" href="#profile"> *@
                    @*         <img src="path/to/profile-pic.jpg" alt="Profile Picture" class="rounded-circle" width="20" height="20"> *@
                    @*     </a> *@
                    @* </li> *@
                    <div class="dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                            Profile
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink">
                            <li><a class="dropdown-item" href="/User/Profile">View Profile</a></li>
                            <li><a class="dropdown-item" href="/User/Message">Messages</a></li>
                                <li>
                                    <a asp-action="MySavedProperties" asp-controller="UserProperties" class="dropdown-item" href="/UserProperties/MySavedProperties">Saved Properties</a>
                                </li>
                                <li>
                                    <a asp-action="MyBookings" asp-controller="UserProperties" class="dropdown-item" href="/UserProperties/MyBookings">Bookings</a>
                                </li>
                            <!-- Conditional menu items based on UserType -->
                            @if (ViewBag.UserType == "Owner")
                            {
                                <li><a class="dropdown-item" href="/Property/AddProperty">Add Property</a></li>
                                <li><a class="dropdown-item" href="/Property/ViewMyListings">View My Listings</a></li>
                            }

                            <li><a class="dropdown-item" href="/User/Logout">Log Out</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <!-- If the user is not logged in, show the login link -->
                    <li class="nav-item">
                        <a class="nav-link" href="/User/Login">Log in</a>
                    </li>
                }

                <li class="nav-item">
                    <a class="nav-link" href="#testimonials">Testimonials</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#contact">Contact</a>
                </li>
            </ul>
        </div>
    </div>
</nav>







    

    <!-- Login Success Modal -->
    @if (!string.IsNullOrEmpty(loginSuccessMessage))
    {
        <div class="modal fade" id="loginSuccessModal" tabindex="-1" aria-labelledby="loginSuccessModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="loginSuccessModalLabel">Login Successful</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        @loginSuccessMessage
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <script type="text/javascript">
            var loginModal = new bootstrap.Modal(document.getElementById('loginSuccessModal'));
            loginModal.show();
        </script>
    }

    <!-- Logout Confirmation Modal -->
    @if (showLogoutConfirm)
    {
        <div class="modal fade" id="logoutConfirmModal" tabindex="-1" aria-labelledby="logoutConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="logoutConfirmModalLabel">Are you sure you want to log out?</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <a href="/User/Logout" class="btn btn-primary">Yes, Log out</a>
                    </div>
                </div>
            </div>
        </div>

        <script type="text/javascript">
            var logoutModal = new bootstrap.Modal(document.getElementById('logoutConfirmModal'));
            logoutModal.show();
        </script>
    }

 
   



