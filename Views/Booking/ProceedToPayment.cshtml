@model dynamic
@{
    ViewData["Title"] = "Proceed to Payment";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EthioHomes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #2563eb;
            --secondary: #1e40af;
            --accent: #10b981;
            --light: #f8fafc;
            --dark: #1e293b;
        }

        body {
            background: url(/images/Image.png) center/cover fixed;
            backdrop-filter: blur(5px);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .navbar {
            background: transparent !important;
            backdrop-filter: blur(6px);
        }

        .payment-container {
            background: transparent;
            backdrop-filter:blur(5px);
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 2rem;
            margin: 2rem auto;
            max-width: 800px;
        }

        .payment-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            background: rgba(255, 255, 255, 0.9);
        }

        .btn-confirm {
            background: linear-gradient(90deg, #2563eb 0%, #10b981 100%);
            ;
            color: white;
            border-radius: 25px;
            padding: 12px 30px;
            transition: all 0.3s ease;
        }

            .btn-confirm:hover {
                transform: scale(1.05);
                box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            }

        .btn-back {
            background: var(--color-light);
            border-radius: 25px;
            padding: 8px 20px;
            transition: all 0.3s ease;
        }

            .btn-back:hover {
                background: var(--color-accent);
                color: white;
                transform: translateX(-5px);
            }

        @@media (max-width: 768px) {
            .payment-container {
                margin: 1rem;
                padding: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <h2 class="text-white fw-bold"><i class="fas fa-home me-2 text-white"></i>EthioHomes</h2>
            </a>
        </div>
    </nav>

    <main class="container py-5 mt-5">
        <div class="payment-container">
            <button onclick="history.back()" class="btn btn-back mb-4">
                <i class="fas fa-arrow-left me-2"></i>Back
            </button>

            <h2 class="text-center mb-4 fw-bold text-white">Confirm Your Payment</h2>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <div>@TempData["Error"]</div>
                </div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success d-flex align-items-center">
                    <i class="fas fa-check-circle me-2"></i>
                    <div>@TempData["Success"]</div>
                </div>
            }

            <div class="payment-card card p-4 mb-4">
                <h4 class="text-secondary mb-3"><i class="fas fa-file-invoice-dollar me-2"></i>Booking Summary</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <p><strong><i class="fas fa-home me-2"></i>Property:</strong> @Model.PropertyTitle</p>
                        <p><strong><i class="fas fa-user me-2"></i>Booked By:</strong> @Model.UserName</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong><i class="fas fa-user-tie me-2"></i>Owner:</strong> @Model.OwnerName</p>
                        <p>
                            <strong><i class="fas fa-calendar-alt me-2"></i>Duration:</strong>
                            @Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()
                        </p>
                    </div>
                </div>
                <div class="mt-3">
                    <p class="h5" style="color: var(--color-primary);">
                        <strong><i class="fas fa-coins me-2"></i>Total Amount:</strong>
                        @Model.Price.ToString("C")
                    </p>
                </div>
            </div>

            <div class="alert alert-warning mt-4 d-flex align-items-center">
                <i class="fas fa-exclamation-circle me-2"></i>
                <div>
                    <strong>Important:</strong> This booking becomes final upon confirmation.
                    Refunds and cancellations require owner approval.
                </div>
            </div>

            <form action="@Url.Action("StartChapaPayment", "Booking")" method="post">
                <input type="hidden" name="BookingId" value="@Model.BookingId" />

                <div class="form-group">
                    <label for="PayerPhone">Your Phone Number (for Telebirr):</label>
                    <input type="text" class="form-control" id="PayerPhone" name="PayerPhone" required placeholder="e.g. 0912345678">
                </div>

                <button type="submit" class="btn btn-confirm"><i class="fas fa-credit-card me-2"></i>Pay with Telebirr</button>
            </form>

            <form method="post" action="@Url.Action("CompletePayment", "Booking")" class="text-center">
                <input type="hidden" name="bookingId" value="@Model.BookingId" />
                <button type="submit" class="btn btn-confirm">
                    <i class="fas fa-credit-card me-2"></i>Confirm & Pay Now
                </button>
            </form>

            <div class="text-center mt-4">
                <a asp-controller="User" asp-action="Dashboard" class="btn btn-back">
                    <i class="fas fa-home me-2"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </main>

    <footer class="text-center py-4 mt-auto">
        <div class="container">
            <p class="mb-0 text-white">&copy; 2025 EthioHomes. All rights reserved</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Add smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>