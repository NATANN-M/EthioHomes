@model List<dynamic>

<h2>Booking Requests</h2>

@if (Model.Count == 0)
{
    <p>No bookings found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Property</th>
                <th>Requested By</th>
                <th>Stay Duration</th>
                <th>Message</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.PropertyTitle</td>
                    <td>@booking.UserName</td>
                    <td>@booking.StartDate.ToShortDateString() - @booking.EndDate.ToShortDateString()</td>
                    <td>@booking.MessageToOwner</td>
                    <td>@booking.Status</td>
                    <td>
                        @if (booking.Status == "Pending")
                        {
                            <form method="post" asp-action="ApproveBooking" asp-controller="Booking">
                                <input type="hidden" name="bookingId" value="@booking.Id" />
                                <button class="btn btn-success btn-sm">Approve</button>
                            </form>
                            <form method="post" asp-action="RejectBooking" asp-controller="Booking">
                                <input type="hidden" name="bookingId" value="@booking.Id" />
                                <button class="btn btn-danger btn-sm">Reject</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">@booking.Status</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
