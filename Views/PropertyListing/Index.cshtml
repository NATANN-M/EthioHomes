@model List<EthioHomes.Models.Property>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EthioHomes - Explore Properties</title>

    <!-- Custom CSS -->
    <style>
        :root {
            --color-primary: #2A2A2A;
            --color-accent: #FF6B6B;
            --color-light: #F4F4F4;
            --color-dark: #1A1A1A;
        }

        body {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url(/images/Image.png) center/cover fixed;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .navbar {
            background: rgba(42, 42, 42, 0.95) !important;
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
        }

        .property-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: none;
            border-radius: 15px;
            overflow: hidden;
            background: rgba(255,255,255,0.95);
        }

            .property-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            }

        .card-img-top {
            height: 250px;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .property-card:hover .card-img-top {
            transform: scale(1.03);
        }

        .price-tag {
            position: absolute;
            top: 15px;
            right: 15px;
            background: var(--color-accent);
            color: white;
            padding: 5px 15px;
            border-radius: 25px;
            font-weight: 600;
        }

        .btn-custom {
            background: var(--color-accent);
            color: white;
            border-radius: 25px;
            padding: 8px 25px;
            transition: all 0.3s ease;
        }

            .btn-custom:hover {
                background: #ff5252;
                transform: translateY(-2px);
            }

        .search-form .form-control {
            border-radius: 25px;
            padding: 12px 20px;
            border: 2px solid var(--color-light);
        }

            .search-form .form-control:focus {
                border-color: var(--color-accent);
                box-shadow: none;
            }

        footer {
            margin-top: auto;
            background: rgba(26, 26, 26, 0.95);
            backdrop-filter: blur(5px);
        }
    </style>

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/Home/index">
                <h2 class="text-white fw-bold"><i class="fas fa-home me-2"></i>EthioHomes</h2>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon text-white"><i class="fas fa-bars"></i></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white active" href="/Home/index#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Home/index#testimonials">Testimonials</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Home/index#Contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-5 mt-5">
        <div class="container">
            <h1 class="text-center text-white mb-5 display-4 fw-bold">Discover Your Dream Home</h1>

            <!-- Improved Search Form -->
            <form method="get" asp-action="Index" class="row g-3 mb-5 search-form">
                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0"><i class="fas fa-map-marker-alt"></i></span>
                        <input type="text" class="form-control" id="location" name="location"
                               placeholder="Location...">
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0"><i class="fas fa-building"></i></span>
                        <select id="propertyType" name="propertyType" class="form-select">
                            <option value="">All Types</option>
                            <option value="Apartment">Apartment</option>
                            <option value="House">House</option>
                            <option value="Condo">Condo</option>
                        </select>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0"><i class="fas fa-tag"></i></span>
                        <input type="number" id="maxPrice" name="maxPrice" class="form-control"
                               placeholder="Max Price">
                    </div>
                </div>

                <div class="col-12 text-center">
                    <button type="submit" class="btn btn-custom px-5">
                        <i class="fas fa-search me-2"></i>Search
                    </button>
                </div>
            </form>

            <!-- Enhanced Property Listings -->
            <div id="property-list" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @if (Model.Count > 0)
                {
                    @foreach (var property in Model)
                    {
                        <div class="col">
                            <div class="card property-card h-100">
                                <div class="position-relative">
                                    @if (property.Images.Count > 0)
                                    {
                                        <img src="/uploads/@property.Images.FirstOrDefault()?.ImagePath"
                                             class="card-img-top" alt="Property Image">
                                    }
                                    else
                                    {
                                        <img src="/images/no-image-available.png"
                                             class="card-img-top" alt="No Image">
                                    }
                                    <div class="price-tag">$@property.Price</div>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title fw-bold mb-3">@property.Title</h5>
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="fas fa-map-marker-alt me-2 text-muted"></i>
                                        <span class="text-muted">@property.Location</span>
                                    </div>
                                    <div class="d-flex align-items-center mb-3">
                                        <i class="fas fa-home me-2 text-muted"></i>
                                        <span class="badge bg-light text-dark">@property.PropertyType</span>
                                    </div>
                                    <a href="/Property/Details/@property.Id"
                                       class="btn btn-custom w-100">
                                        View Details <i class="fas fa-arrow-right ms-2"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-info text-center py-4">
                            <h4 class="mb-0">No properties found matching your criteria</h4>
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>

    <footer class="py-4 mt-5">
        <div class="container text-center text-white">
            <div class="d-flex justify-content-center mb-3">
                <a href="#" class="text-white mx-3"><i class="fab fa-facebook fa-lg"></i></a>
                <a href="#" class="text-white mx-3"><i class="fab fa-twitter fa-lg"></i></a>
                <a href="#" class="text-white mx-3"><i class="fab fa-instagram fa-lg"></i></a>
            </div>
            <p class="mb-0">&copy; 2025 EthioHomes. All rights reserved.</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Add smooth scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            if (window.scrollY > 50) {
                document.querySelector('.navbar').style.background = 'rgba(26, 26, 26, 0.98)';
            } else {
                document.querySelector('.navbar').style.background = 'rgba(42, 42, 42, 0.95)';
            }
        });
    </script>
</body>
</html>