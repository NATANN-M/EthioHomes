@model EthioHomes.Models.Property

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Property - EthioHomes</title>
    <style>
        :root {
            --color-primary: #2A2A2A;
            --color-accent: #FF6B6B;
            --color-light: #F4F4F4;
            --color-dark: #1A1A1A;
        }

        .edit-property {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 2rem;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--color-dark);
        }

        input, select, textarea {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

            input:focus, select:focus, textarea:focus {
                border-color: var(--color-accent);
                box-shadow: 0 0 8px rgba(255, 107, 107, 0.2);
            }

        .form-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            margin-top: 2rem;
        }

        .btn-primary {
            background: var(--color-accent);
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background: #ff5252;
                transform: translateY(-2px);
            }

        .btn-secondary {
            background: #ddd;
            color: var(--color-dark);
        }

        @@media (max-width: 768px) {
            .edit-property {
                padding: 1rem;
                margin: 1rem;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    <!-- Include your existing header links -->
</head>
<body>
    <!-- Include your existing navigation -->

    <div class="container py-5">
        <div class="edit-property">
            <h2 class="text-center mb-5 display-5 fw-bold">Edit Property</h2>

            <form asp-action="EditProperty" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="form-grid">
                    <!-- Title -->
                    <div class="form-group">
                        <label asp-for="Title">Property Title</label>
                        <input type="text" asp-for="Title"
                               value="@Model.Title"
                               placeholder="Enter property title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <!-- Location -->
                    <div class="form-group">
                        <label asp-for="Location">Location</label>
                        <input type="text" asp-for="Location"
                               value="@Model.Location"
                               placeholder="Enter property location" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <!-- Price -->
                    <div class="form-group">
                        <label asp-for="Price">Price ($)</label>
                        <input type="number" asp-for="Price"
                               value="@Model.Price"
                               step="0.01"
                               placeholder="Enter price" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <!-- Property Type -->
                    <div class="form-group">
                        <label asp-for="PropertyType">Property Type</label>
                        <select asp-for="PropertyType" class="form-select">
                            <option value="Residential" selected="@(Model.PropertyType == "Residential")">Residential</option>
                            <option value="Commercial" selected="@(Model.PropertyType == "Commercial")">Commercial</option>
                        </select>
                        <span asp-validation-for="PropertyType" class="text-danger"></span>
                    </div>

                    <!-- Status -->
                    <div class="form-group">
                        <label asp-for="Status">Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Available" selected="@(Model.Status == "Available")">Available</option>
                            <option value="Sold" selected="@(Model.Status == "Sold")">Sold</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <!-- Bedrooms -->
                    <div class="form-group">
                        <label asp-for="Bedrooms">Bedrooms</label>
                        <input type="number" asp-for="Bedrooms"
                               value="@Model.Bedrooms"
                               placeholder="Number of bedrooms" />
                        <span asp-validation-for="Bedrooms" class="text-danger"></span>
                    </div>

                    <!-- Bathrooms -->
                    <div class="form-group">
                        <label asp-for="Bathrooms">Bathrooms</label>
                        <input type="number" asp-for="Bathrooms"
                               value="@Model.Bathrooms"
                               placeholder="Number of bathrooms" />
                        <span asp-validation-for="Bathrooms" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="form-group full">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description"
                                  rows="5"
                                  placeholder="Describe your property in detail">@Model.Description</textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                    <a href="@Url.Action("Details", "Property", new { id = Model.Id })"
                       class="btn btn-secondary">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Include your existing footer -->
    <!-- Validation Scripts -->
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }

    <script>
        // Initialize form validation
        (function () {
            'use strict'
            const forms = document.querySelectorAll('.needs-validation')

            Array.from(forms)
                .forEach(form => {
                    form.addEventListener('submit', event => {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }

                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
</body>
</html>