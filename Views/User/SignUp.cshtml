@model EthioHomes.Models.User

@{
    ViewData["Title"] = "Sign Up";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style_login.css" asp-append-version="true" />
    <title>Sign Up</title>

    <style>

        :root {
            --primary: #2563eb;
            --secondary: #1e40af;
            --accent: #10b981;
            --light: #f8fafc;
            --dark: #1e293b;
        }

        #signup-btn, #learn-more {
            font-size: 1.25rem;
            font-weight: 700;
            padding-left: 2rm;
            padding: 2rm;
            border-radius: 2rem;
            background: linear-gradient(90deg, #2563eb 0%, #10b981 100%);
            color: #fff !important;
            box-shadow: 0 4px 16px rgba(37,99,235,0.15);
            border: none;
            transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
            letter-spacing: 1px;
        }

            #signup-btn:hover, .login-btn:focus {
                background: linear-gradient(90deg, #10b981 0%, #2563eb 100%);
                color: #fff !important;
                box-shadow: 0 8px 24px rgba(16,185,129,0.18);
                transform: translateY(-2px) scale(1.04);
                text-decoration: none;
            }
    </style>
</head>
<body class="p-4">
    <nav id="navbar" class="navbar navbar-expand-sm">
        <div class="container">
            <a class="navbar-brand" href="/Home/index">
                <h2 class="text-white fw-bold"><i class="fas fa-home me-2"></i>EthioHomes</h2>
            </a>
        </div>
    </nav>
    <div class="flex container-fluid container  rounded-4 p-2 text-white">
        <div class="left_flex mt-2 ms-5">
            <header><h1 class="text-center"></h1></header>
            <hr />
            <div class="left_flex_text">
                <h1 class="mb-3">
                    Create <br />
                    New Account
                </h1>
                <h6 class="mb-3">
                    Already Registered?
                    <a class="text-blue m-md-2" asp-controller="User" asp-action="Login"
                        href="@Url.Action("Login","User")">Login</a>
                </h6>
                <hr class="rounded-4" />
                <div class="w-75 mb-4">
                    <h5>
                        The Perfect Place to Find Your Dream Home.</br>
                    </h5>
                </div>
                <button class="btn btn-dark rounded-5 mt-2" id="learn-more">Learn More</button>
            </div>
        </div>
        <div class="right_flex w-40 mt-4">
            <div class="right_flex_text mt-2">
               
                <form method="post" class="bd-filter px-5 py-3 rounded-5">
                    <h1 class="text-center text-white">Sign Up</h1>
                    <label class="form-label">Name</label>
                    <input type="text" name="Name" class="form-control rounded-4" placeholder="Enter your Fullname..." required />
                    <br />
                    <label class="form-label">Email</label>
                    <input type="email" name="Email" class="form-control rounded-4" placeholder="Enter Email..." required />
                    <br />
                    <label class="form-label">Password</label>
                    <input type="password" name="Password" class="form-control rounded-4" placeholder="Enter Password..." required />
                    <br />
                    <div>
                        <label class="form-label">User Type</label>
                        <select name="UserType" class="form-select rounded-4">
                            <option value="Tenant">Tenant/Buyer</option>
                            <option value="Owner">Owner</option>
                        </select>
                    </div>
                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-primary text-center" id="signup-btn">Sign Up</button>
                    </div>
                </form>
                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success mt-3">
                        <p>@ViewBag.Message</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
            crossorigin="anonymous"></script>
    <script src="~/js/scripts.js" asp-append-version="true"></script>
    <script src="~/js/script2.js" asp-append-version="true"></script>
</body>
</html>
