@model EthioHomes.Models.User

@{
    ViewData["Title"] = "Sign Up";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style_login.css" asp-append-version="true" />
    <title>Sign Up</title>
</head>
<body class="p-4">
    <nav id="navbar" class="navbar navbar-expand-sm">
        <div class="container">
            <a class="navbar-brand" href="/Home/index">
                <h1 style="color: white;"><em>Ethio Homes</em></h1>
            </a>
        </div>
    </nav>
    <div class="flex container-fluid container  rounded-4 p-2 text-white">
        <div class="left_flex mt-2 ms-5">
            <header><h1 class="text-center"></h1></header>
            <hr />
            <div class="left_flex_text">
                <h1 class="mb-3">
                    Create <br />
                    New Account
                </h1>
                <h6 class="mb-3">
                    Already Registered?
                    <a class="text-white" asp-controller="User" asp-action="Login"
                        href="@Url.Action("Login","User")">Login</a>
                </h6>
                <hr class="rounded-4" />
                <div class="w-75 mb-4">
                    <h5>
                        The Perfect Place to Find Your Dream Home.</br>
                    </h5>
                </div>
                <button class="btn btn-dark rounded-5 mt-2">Learn More</button>
            </div>
        </div>
        <div class="right_flex w-40 mt-4">
            <div class="right_flex_text mt-2">
               
                <form method="post" class="bd-filter px-5 py-3 rounded-5">
                    <h1 class="text-center text-white">Sign Up</h1>
                    <label class="form-label">Name</label>
                    <input type="text" name="Name" class="form-control rounded-4" required />
                    <br />
                    <label class="form-label">Email</label>
                    <input type="email" name="Email" class="form-control rounded-4" required />
                    <br />
                    <label class="form-label">Password</label>
                    <input type="password" name="Password" class="form-control rounded-4" required />
                    <br />
                    <div>
                        <label class="form-label">User Type</label>
                        <select name="UserType" class="form-select rounded-4">
                            <option value="Owner">Owner</option>
                            <option value="Tenant">Buyer/Tenant</option>
                        </select>
                    </div>
                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-primary text-center">Sign Up</button>
                    </div>
                </form>
                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success mt-3">
                        <p>@ViewBag.Message</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
            crossorigin="anonymous"></script>
    <script src="~/js/scripts.js" asp-append-version="true"></script>
    <script src="~/js/script2.js" asp-append-version="true"></script>
</body>
</html>
