@model EthioHomes.Models.Property

<h2>@Model.Title</h2>

<!-- Display images -->

<div >
    <h3>Images</h3>
    @if (Model.Images.Count > 0)
    {
        @foreach (var image in Model.Images)
        {
            <img src="/uploads/@image.ImagePath" alt="Property Image" style="width:200px; height:auto; margin:10px;" />
        }
    }
    else
    {
        <p>No images available</p>
    }
</div>

<p><strong>Location:</strong> @Model.Location</p>
<p><strong>Price:</strong> @Model.Price</p>
<p><strong>Type:</strong> @Model.PropertyType</p>
<p><strong>Status:</strong> @Model.Status</p>
<p><strong>Bedrooms:</strong> @Model.Bedrooms</p>
<p><strong>Bathrooms:</strong> @Model.Bathrooms</p>
<p><strong>Description:</strong> @Model.Description</p>




<!-- Actions -->
<div>
    <a href="/Messages/ViewMessages?propertyId=@Model.Id" class="btn btn-primary">Contact Owner</a>

    <form action="@Url.Action("SaveProperty", "PropertyActions")" method="post">
        <input type="hidden" name="propertyId" value="@Model.Id" />
        <button type="submit" class="btn btn-success">Save Property</button>
    </form>

    <form action="@Url.Action("BookProperty", "PropertyActions")" method="post">
        <input type="hidden" name="propertyId" value="@Model.Id" />
        <button type="submit" class="btn btn-warning">Book Property</button>
    </form>

</div>
