@model List<EthioHomes.Models.Property>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Listings</title>

    <!-- Stylesheets -->
    <link rel="stylesheet" href="~/css/styleNavigation.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
         :root {
        --primary: #2563eb;
        --secondary: #1e40af;
        --accent: #10b981;
        --light: #f8fafc;
        --dark: #1e293b;
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background:  url(/images/Image.png) center/cover fixed;
            backdrop-filter: blur(5px);
            min-height: 100vh;
          
        }

        .navbar {
            position:sticky;
            background: transparent;
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
        }

        .page-header {
            padding: 3rem 0 1.5rem;
            background: linear-gradient(45deg, #0d6efd, #00b4d8);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            position: relative;
        }

        .listing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
            padding: 2rem 0;
        }

        .property-card {
            background: white;
            border-radius: 1rem;
            overflow: hidden;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
            border: 1px solid rgba(0, 0, 0, 0.1);
        }

            .property-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.12);
            }

        .card-image {
            height: 220px;
            background: #f8f9fa;
            position: relative;
            overflow: hidden;
        }

            .card-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.3s ease;
            }

            .card-image:hover img {
                transform: scale(1.05);
            }

        .card-body {
            padding: 1.5rem;
        }

        .card-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
            color: var(--dark);
        }

        .card-text {
            color: #6c757d;
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .property-meta {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
        }

        .status-badge {
            padding: 0.35rem 0.75rem;
            border-radius: 1rem;
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: capitalize;
        }

        .card-actions {
            display: flex;
            gap: 0.75rem;
            padding: 1rem 1.5rem;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
        }

        .btn-action {
            flex: 1;
            padding: 0.75rem;
            border-radius: 0.75rem;
            font-weight: 500;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-edit {
            background: rgba(var(--accent), 0.1);
            color: var(--primary);
        }

            .btn-edit:hover {
                background: var(--accent);
                color: white;
            }

        .btn-delete {
            background: rgba(var(--danger), 0.1);
            color: var(--danger);
        }

            .btn-delete:hover {
                background: var(--danger);
                color: red;
            }

        @@media (max-width: 768px) {
            .listing-grid {
                grid-template-columns: 1fr;
            }

            .page-header {
                padding: 4rem 0 2rem;
            }

            .card-image {
                height: 200px;
            }

            .btn-action {
                font-size: 0.9rem;
                padding: 0.6rem;
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .property-card {
            animation: fadeIn 0.4s ease forwards;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/Home/index">
                <h2 class="text-white fw-bold"><i class="fas fa-home me-2"></i>EthioHomes</h2>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/index#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/index#testimonials">Testimonials</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/index#Contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <header class="page-header">
        <div class="container text-center">
            <h1 class="display-4 fw-bold mb-3t text-white">My Listings</h1>
            <p class="lead text-muted text-white">Manage your property listings</p>
        </div>
    </header>

    <main class="container">
        <div class="listing-grid">
            @foreach (var property in Model)
            {
                <article class="property-card">
                    <div class="card-image">
                        @if (property.ImagePaths.Count > 0)
                        {
                            <img src="/uploads/@property.ImagePaths.First()" alt="@property.Title" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <i class="bi bi-image fs-1"></i>
                            </div>
                        }
                    </div>

                    <div class="card-body">
                        <h2 class="card-title">@property.Title</h2>

                        <div class="property-meta">
                            <div class="meta-item">
                                <i class="bi bi-tag-fill text-primary"></i>
                                <span>@property.Price.ToString("C")</span>
                            </div>
                            <div class="meta-item">
                                <i class="bi bi-building text-primary"></i>
                                <span class="status-badge bg-@GetStatusColor(property.Status)">
                                    @property.Status
                                </span>
                            </div>
                        </div>

                        <p class="card-text">@property.Description</p>
                    </div>

                    <div class="card-actions">
                        <a href="/ManageProperty/EditProperty/@property.Id"
                           class="btn-action btn-edit">
                            <i class="bi bi-pencil-square"></i>
                            Edit
                        </a>
                        <form action="/ManageProperty/DeleteProperty/@property.Id" method="post">
                            <button type="submit"
                                    class="btn-action btn-delete"
                                    onclick="return confirm('Are you sure you want to delete this listing?')">
                                <i class="bi bi-trash"></i>
                                Delete
                            </button>
                        </form>
                    </div>
                </article>
            }
        </div>
    </main>

    <!-- Bootstrap JS -->
    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>

@functions {
    string GetStatusColor(string status)
    {
        return status switch
        {
            "Available" => "success",
            "Rented" => "danger",
            "Pending" => "warning",
            _ => "secondary"
        };
    }
}