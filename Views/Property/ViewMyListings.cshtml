@model List<EthioHomes.Models.Property>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/css/styleNavigation.css" asp-append-version="true">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <!-- Bootstrap (Local Copy) -->
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true">
    <!-- Owl Carousel (Local Copy) -->
    <title>My Listings</title>
    <style>
        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f9f9fc;
            color: #333;
            background-image: url(/images/Image.png);
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        header {
            color: #ffffff;
            padding: 1rem 0;
            text-align: center;

        }

        header h1 {
            margin: 0;
            font-size: 2.5rem;
        }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: 2rem auto;
        }

        .property-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
        }

        .property-card {
            background: #ffffff;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .property-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
        }

        .property-image img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .property-details {
            padding: 1rem 1.5rem;
        }

        .property-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin: 0 0 0.5rem;
            color: #35424a;
        }

        .property-info {
            margin: 0.5rem 0;
            line-height: 1.6;
            color: #555;
        }

        .property-actions {
            display: flex;
            justify-content: space-between;
            padding: 1rem 1.5rem;
        }

        .btn {
            padding: 0.8rem 1.5rem;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            transition: background-color 0.3s ease;
        }

        .btn-edit {
            background-color: #42a5f5;
            color: #ffffff;
        }

        .btn-edit:hover {
            background-color: #1e88e5;
        }

        .btn-delete {
            background-color: #ef5350;
            color: #ffffff;
        }

        .btn-delete:hover {
            background-color: #d32f2f;
        }
    </style>
</head>

<body>
    <nav id="navbar" class="navbar navbar-expand-sm" >
        <div class=" container" >
            <a class="navbar-brand" href="/Home/index">
                <h1 style="color: white;"><em>Ethio Homes</em></h1>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-main">
                <span class="navbar-toggler-icon"><i class="fas fa-bars"></i></span>
            </button>
            <div class="collapse navbar-collapse" id="navbar-main">
                <ul class="navbar-nav ml-auto mb-2 mb-lg-0">
                    <li style="color: white;" class="nav-item">
                        <a class="nav-link active" href="/Home/index#about">About</a>
                    </li>
                    <li style="color: white;" class="nav-item">
                        <a class="nav-link" href="/Home/index#testimonials">Testimonials</a>
                    </li>
                    <li style="color: white;" class="nav-item">
                        <a class="nav-link" href="/Home/index#Contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <header>
        <h1 style="margin-top: 8rem;">My Listings</h1>
    </header>
    <div class="container" style="margin-top: 5rem;">
        <div class="property-list">
            @foreach (var property in Model)
            {
                <div class="property-card">
                    <div class="property-image" style="">
                        @if (property.ImagePaths.Count > 0)
                        {
                            foreach (var imagePath in property.ImagePaths)
                            {
                                <img src="/uploads/@imagePath" alt="Property Image" style="width:100%;height: 200px;" />
                            }
                        }
                        else
                        {
                            <p>No images available</p>
                        }
                    </div>
                    <div class="property-details">
                        <h2 class="property-title">@property.Title</h2>
                        <p class="property-info">Price: @property.Price</p>
                        <p class="property-info">Status: @property.Status</p>
                        <p class="property-info">@property.Description</p>
                    </div>
                    <div class="property-actions">
                        <a href="/ManageProperty/EditProperty/@property.Id" class="btn btn-edit">Edit</a>
                        <form action="/ManageProperty/DeleteProperty/@property.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-delete">Delete</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</body>

</html>
