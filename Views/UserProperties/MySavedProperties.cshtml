@model List<EthioHomes.Models.Property>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EthioHomes - Explore Properties</title>
    <!-- Custom CSS Files -->

   

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <!-- Bootstrap (Local Copy) -->
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true">
</head>

<body>


        <div class="container py-4">
            <h2 class="text-center mb-4">My Saved Properties</h2>
            @if (Model.Count == 0)
            {
                <p class="text-center text-muted">No saved properties found.</p>
            }
            else
            {
                <div class="row">
                    @foreach (var property in Model)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="property-card p-3 border rounded">
                                @* <img src="/uploads/@Model.Images[0].ImagePath" alt="@property.Title" class="img-fluid mb-3 rounded">*@
                                <h4>@property.Title</h4>
                                <p><strong>Location:</strong> @property.Location</p>
                                <p><strong>Price:</strong> @string.Format("{0:C}", property.Price)</p>
                                <p><strong>Type:</strong> @property.PropertyType</p>
                                <p><strong>Status:</strong> @property.Status</p>
                                <a asp-action="Details" asp-controller="Property" asp-route-id="@property.Id"
                                    class="btn btn-primary">View Details</a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <footer class="text-center mt-4">
            <p>&copy; 2025 EthioHomes. All Rights Reserved.</p>
        </footer>
        <script src="~/js/bootstrap.bundle.min.js"></script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
