@model List<EthioHomes.Models.Booking>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Your Bookings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Stylesheets -->
    <link rel="stylesheet" href="~/css/styleNavigation.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: url(/images/Image.png) center/cover fixed;
            backdrop-filter: blur(5px);
            min-height: 100vh;
        }
        /* Modern Navigation */
        .navbar {
            background: transparent !important;
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
            padding: 0.5rem 0;
            color: white;
        }

        .navbar-brand {
            font-weight: 700;
            color: var(--dark) !important;
            transition: transform 0.2s ease;
        }

            .navbar-brand:hover {
                transform: translateX(-3px);
            }

        .nav-link {
            color: white !important;
            font-weight: 500;
            position: relative;
            margin: 0 1rem;
            transition: all 0.2s ease;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 0;
                height: 2px;
                background: var(--primary);
                transition: width 0.3s ease;
            }

            .nav-link:hover::after,
            .nav-link.active::after {
                width: 100%;
            }


        .booking-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
            background: linear-gradient(145deg, #ffffff, #f8f9fa);
            margin-bottom: 1.5rem;
        }

            .booking-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            }

        .status-badge {
            font-size: 0.9rem;
            padding: 0.35rem 0.75rem;
            border-radius: 20px;
        }

        .payment-status {
            font-weight: 600;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
        }

        .gradient-text {
            background: linear-gradient(45deg, #0d6efd, #00b4d8);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .detail-item {
            margin-bottom: 0.75rem;
            padding: 0.5rem 0;
            border-bottom: 1px solid #eee;
        }

            .detail-item:last-child {
                border-bottom: none;
            }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/Home/index">
                <h2 class="mb-0 text-white">
                    <i class="fas fa-home me-2 text-white"></i>EthioHomes
                </h2>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"><i class="fas fa-bars"></i></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/Home/index#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/index#testimonials">Testimonials</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/index#Contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>


    <div class="container py-5">
        <h1 class="display-5 text-center mb-5 fw-bold text-white">Your Bookings</h1>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="alert alert-info py-4">
                    <i class="bi bi-calendar-x fs-1"></i>
                    <h3 class="mt-3">No Active Bookings</h3>
                    <p class="text-muted">You don't have any active bookings at the moment.</p>
                </div>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var booking in Model)
                {
                    <div class="col">
                        <div class="booking-card p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="h4 mb-0">
                                    @if (booking.Property != null)
                                    {
                                        @booking.Property.Title
                                    }
                                    else
                                    {
                                        <span>Property ID: @booking.PropertyId</span>
                                    }
                                </h3>
                                <span class="status-badge bg-@(booking.Status == "Approved" ? "success" : "warning") text-white">
                                    @booking.Status
                                </span>
                            </div>

                            @if (booking.Property != null)
                            {
                                <div class="detail-item">
                                    <i class="bi bi-geo-alt me-2 text-primary"></i>
                                    <strong>Location:</strong> @booking.Property.Location
                                </div>
                                <div class="detail-item">
                                    <i class="bi bi-tag me-2 text-primary"></i>
                                    <strong>Price:</strong> @booking.Property.Price.ToString("N0") ETB
                                </div>
                            }

                            <div class="detail-item">
                                <i class="bi bi-calendar-range me-2 text-primary"></i>
                                <strong>Dates:</strong>
                                @booking.StartDate.ToString() - @booking.EndDate.ToString()
                            </div>

                            <div class="row g-2 mt-3">
                                <div class="col-6">
                                    <div class="bg-light p-2 rounded text-center">
                                        <small class="text-muted d-block">Booking Date</small>
                                        <strong>@booking.BookingDate.ToString("MMM dd, yyyy")</strong>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light p-2 rounded text-center">
                                        <small class="text-muted d-block">Agreement</small>
                                        <strong class="text-@(booking.AgreementAccepted ? "success" : "danger")">
                                            @(booking.AgreementAccepted ? "Accepted" : "Pending") 
                                        </strong>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-4">
                                <div class="payment-status bg-@(booking.IsPaid ? "success" : "warning")-subtle text-@(booking.IsPaid ? "success" : "warning")">
                                    <i class="bi bi-@(booking.IsPaid ? "check-circle" : "clock-history") me-2"></i>
                                    @(booking.IsPaid ? "Payment Complete" : "Payment Pending")
                                </div>

                                @if (booking.Status == "Approved" && !booking.IsPaid)
                                {
                                    <form method="get" action="@Url.Action("NextStep", "Booking")">
                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                                            <i class="bi bi-arrow-right-circle me-2"></i>Proceed
                                        </button>
                                    </form>

                                  
                                }


                                @if (!booking.IsPaid)
                                {
                                    <form method="post" action="@Url.Action("CancelBooking", "UserProperties", new { bookingId = booking.Id })" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                        <button type="submit" class="btn btn-danger rounded-pill px-4">
                                            <i class="bi bi-x-circle me-2"></i>Cancel Booking
                                        </button>
                                    </form>

                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>